# --- Python & Virtual Environment ---
venv/
.venv/
__pycache__/
*.py[cod]
*$py.class

# --- Database (SQLite) ---
# 프로젝트에서 사용하는 DB 파일은 로컬에서만 유지하는 것이 좋습니다.
instance/
*.db
*.sqlite3

# --- Zigbee2MQTT ---
# Zigbee2MQTT 설치 폴더 내의 로그와 백업 데이터 제외
/opt/zigbee2mqtt/data/log/
/opt/zigbee2mqtt/data/backup/
/opt/zigbee2mqtt/data/coordinator_backup.json
node_modules/

# --- Environment & Secret ---
# 보안을 위해 설정값이나 키가 들어있는 파일 제외
.env
config.py.local

# --- OS Specific ---
.DS_Store
Thumbs.db
